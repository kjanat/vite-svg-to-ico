{
	"lineWidth": 120,
	"extends": "https://raw.githubusercontent.com/kjanat/kjanat/master/configs/dprint.remote.json",
	"excludes": [".github/workflows/capture.yml", ".github/actions/capture/action.yml", "**/tests/fixtures"],
	"malva": { "useTabs": false },
	"markup": {
		"indentWidth": 2,
		"useTabs": false,
		"scriptFormatter": "biome",
		"formatComments": true,
		"quotes": "single",
	},
}
