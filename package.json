{
	"name": "vite-svg-to-ico",
	"version": "3.1.5",
	"description": "Vite plugin that converts SVG to ICO during site build.",
	"workspaces": [
		"tests/smoke/fixture"
	],
	"keywords": [
		"vite-plugin",
		"vite",
		"svg",
		"ico",
		"favicon",
		"converter"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/vite-svg-to-ico.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"default": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"imports": {
		"#vite-svg-to-ico": "./src/index.ts",
		"#internals/*": "./src/*",
		"#pkg": "./package.json"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"bd": "tsdown",
		"build": "tsdown",
		"dev": "tsdown --watch",
		"fmt": "dprint fmt",
		"fmt:cfg:up": "dprint config update -y",
		"fmt:autofix": "dprint fmt --allow-no-files --diff --excludes .github",
		"prepack": "bun --bun bd -l error",
		"prepublishOnly": "run -s test typecheck",
		"tar": "bun pm pack --quiet | awk 'NF{line=$0} END{print line}'",
		"test": "bun test",
		"typecheck": "tsgo --noEmit",
		"lint": "biome lint"
	},
	"dependencies": {
		"@kjanat/dreamcli": "^2.4",
		"sharp": "^0.35"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18",
		"@biomejs/biome": "^2.5",
		"@types/bun": "^1.3",
		"@typescript/native-preview": "^7.0.0-dev",
		"dprint": "^0.54",
		"publint": "^0.3",
		"runner-run": "^0.14",
		"tsdown": "^0.22",
		"typescript": "^6",
		"unplugin-unused": "^0.5",
		"vite": "^8"
	},
	"overrides": {
		"fflate": "0.8.2"
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"packageManager": "bun@1.3.14",
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/",
		"tag": "latest"
	},
	"bin": {
		"svg-to-ico": "dist/cli.mjs"
	}
}
