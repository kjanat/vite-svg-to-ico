{
	"name": "vite-svg-to-ico",
	"version": "4.1.0",
	"description": "Vite plugin that converts SVG to ICO during site build.",
	"keywords": [
		"vite-plugin",
		"vite",
		"svg",
		"ico",
		"favicon",
		"converter",
		"dreamcli",
		"ansispeck"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/vite-svg-to-ico.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"imports": {
		"#vite-svg-to-ico": "./src/index.ts",
		"#internals/*": "./src/*",
		"#types": "./src/types.ts",
		"#faviconTags": "./src/favicon-tags.ts",
		"#injectHtml": "./src/inject-html.ts",
		"#ico": "./src/ico.ts",
		"#raster": "./src/raster.ts",
		"#size": "./src/size.ts",
		"#cli/*": "./src/cli/*.ts",
		"#cli": "./src/cli.ts",
		"#assets": "./src/assets.ts",
		"#config": "./src/config.ts",
		"#devClient": "./src/dev-client.ts",
		"#instrumentation": "./src/instrumentation.ts",
		"#loadInput": "./src/load-input.ts",
		"#dataUri": "./src/data-uri.ts",
		"#resolveSpecs": "./src/resolve-specs.ts",
		"#testHelpers": "./tests/_helpers.ts",
		"#pkg": "./package.json"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"svg-to-ico": "dist/cli.mjs"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"bd": "tsdown",
		"build": "tsdown",
		"check": "biome check",
		"check:fix": "biome check --fix",
		"dev": "tsdown --watch",
		"fmt": "run -s check:fix fmt:dprint",
		"fmt:autofix": "dprint fmt --allow-no-files --diff --excludes .github",
		"fmt:cfg:up": "dprint config update -yr",
		"fmt:dprint": "dprint fmt",
		"lint": "biome lint",
		"prepack": "bun --bun bd -l error",
		"prepublishOnly": "run -s test typecheck",
		"tar": "bun pm pack --quiet | awk 'NF{line=$0} END{print line}'",
		"pretest": "bun pm pack --gzip-level 0 --filename tests/smoke/fixture/vite-svg-to-ico.tgz && bun --cwd=tests/smoke/fixture install --no-frozen-lockfile",
		"test": "bun test",
		"typecheck": "bunx @typescript/native --noEmit"
	},
	"overrides": {
		"fflate": "0.8.2"
	},
	"dependencies": {
		"ansispeck": "^0.1.2",
		"dreamcli": "npm:@kjanat/dreamcli@^3.0.0-rc.9",
		"sharp": "^0.35"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18",
		"@biomejs/biome": "^2.5",
		"@types/bun": "^1.3",
		"@typescript/native": "npm:typescript@^7",
		"dprint": "^0.55.1",
		"publint": "^0.3",
		"runner-run": "^0.19.1",
		"sort-package-json": "^4.0.0",
		"tsdown": "^0.22",
		"typescript": ">=6,<7",
		"unplugin-unused": "^0.5",
		"vite": "^8"
	},
	"packageManager": "bun@1.3.14",
	"engines": {
		"bun": ">=1.3",
		"node": ">=22.22.2"
	},
	"volta": {
		"node": "26.5.0",
		"npm": "11.18.0"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/",
		"tag": "latest"
	}
}
