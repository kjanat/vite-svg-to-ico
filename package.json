{
	"name": "vite-svg-to-ico",
	"version": "3.1.2",
	"description": "Vite plugin that converts SVG to ICO during site build.",
	"workspaces": [
		"tests/smoke/fixture"
	],
	"keywords": [
		"vite-plugin",
		"vite",
		"svg",
		"ico",
		"favicon",
		"converter"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/vite-svg-to-ico.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"default": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"imports": {
		"#vite-svg-to-ico": "./src/index.ts",
		"#internals/*": "./src/*"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"bd": "tsdown",
		"build": "tsdown",
		"dev": "tsdown --watch",
		"fmt": "dprint fmt",
		"prepack": "bun --bun bd -l error",
		"prepublishOnly": "bun test && bun --bun typecheck",
		"tar": "bun pm pack --quiet | awk 'NF{line=$0} END{print line}'",
		"test": "bun test",
		"typecheck": "tsgo --noEmit",
		"lint": "bunx -p @biomejs/biome biome lint"
	},
	"dependencies": {
		"@kjanat/dreamcli": "^2.1.0",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@types/bun": "^1.3.13",
		"@typescript/native-preview": "^7.0.0-dev.20260512.1",
		"dprint": "^0.54.0",
		"publint": "^0.3.20",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"unplugin-unused": "^0.5.7"
	},
	"peerDependencies": {
		"vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"packageManager": "bun@1.3.13",
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/",
		"tag": "latest"
	},
	"bin": {
		"svg-to-ico": "dist/cli.mjs"
	}
}
