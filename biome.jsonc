{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master",
		"root": "."
	},
	"files": {
		"includes": ["**", "!!**/dist", "!!tests/smoke/fixture", "!!*/worktrees/*"]
	},
	"formatter": { "enabled": false },
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": { "recommended": true, "noSvgWithoutTitle": "off" },
			"complexity": { "recommended": true, "useLiteralKeys": "off" },
			"correctness": { "recommended": true, "noNodejsModules": "off" },
			"performance": { "recommended": true },
			"security": { "recommended": true },
			"suspicious": { "recommended": true }
		},
		"domains": {
			"project": "recommended",
			"test": "recommended",
			"types": "recommended"
		}
	},
	"javascript": {},
	"assist": {
		"enabled": true,
		"actions": { "source": { "organizeImports": "on" } }
	}
}
